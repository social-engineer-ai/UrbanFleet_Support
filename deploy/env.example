# Copy this to /opt/stakeholdersim/.env and fill in values

DATABASE_URL="file:./prisma/dev.db"
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"
AUTH_SECRET="generate-a-random-string-here-at-least-32-chars"

# Email (SMTP) for OTP verification
# For AWS SES: use SES SMTP credentials
SMTP_HOST="email-smtp.us-east-1.amazonaws.com"
SMTP_PORT="587"
SMTP_USER="your-ses-smtp-user"
SMTP_PASS="your-ses-smtp-password"
SMTP_FROM="StakeholderSim <noreply@yourdomain.com>"
