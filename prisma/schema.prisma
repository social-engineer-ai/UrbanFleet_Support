generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("student")
  emailVerified Boolean  @default(false)
  course        String?
  teamId        String?
  createdAt     DateTime @default(now())

  team          Team?          @relation(fields: [teamId], references: [id])
  conversations Conversation[]
  studentState  StudentState?
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  course    String
  createdAt DateTime @default(now())

  members          User[]
  leaderboardEntry LeaderboardEntry[]
}

model Conversation {
  id           String    @id @default(cuid())
  userId       String
  agentType    String
  persona      String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  summary      String?
  messageCount Int       @default(0)

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadata       String?
  timestamp      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model StudentState {
  id        String   @id @default(cuid())
  userId    String   @unique
  stateJson String   @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model LeaderboardEntry {
  id              String   @id @default(cuid())
  teamId          String
  course          String
  baselineScore   Int      @default(0)
  enhancedScore   Int      @default(0)
  innovationScore Int      @default(0)
  qualityMultiplier Float  @default(1.0)
  finalScore      Float    @default(0)
  scenarioResults String   @default("{}") // JSON: { "B1": { score: 5, passed: true }, ... }
  auditedAt       DateTime?
  auditNotes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
}

model LeaderboardBonus {
  id      String @id @default(cuid())
  teamId  String
  course  String
  rank    Int
  bonus   Int
}
